# App
NODE_ENV=production
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://cpaplataformafrontend.a2020115468.workers.dev
TRUST_PROXY=true

# PostgreSQL / Neon
PGHOST=ep-empty-unit-adbinioh-pooler.c-2.us-east-1.aws.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=npg_Ewqom61fHanj
PGSSLMODE=require
DB_LOGGING=true

# Seguridad
# En local puedes dejar false para smoke tests de CRUD sin login.
# En producción debe ser true.
AUTH_REQUIRED=false
SESSION_COOKIE_NAME=cpa_session
SESSION_TTL_MINUTES=480
SESSION_COOKIE_SECURE=false
SESSION_SAME_SITE=lax

# Rate limiter sin Redis
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Swagger
SWAGGER_ENABLED=true

# TEST USER
TEST_USER_EMAIL=admin.demo@cpa.test
TEST_USER_USERNAME=admin.demo
TEST_USER_PASSWORD=DemoAdmin123!
SMOKE_DRY_RUN_CRUD_WRITES=true