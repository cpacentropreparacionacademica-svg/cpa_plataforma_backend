{
  "name": "cpa-plataforma-backend-nestjs",
  "version": "2.0.0",
  "description": "Backend CPA Plataforma migrado a NestJS, TypeScript, TypeORM, class-validator y sesiones opacas.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build",
    "start:prod": "node scripts/render-start.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\"",
    "check:source-size": "node scripts/check-source-size.js",
    "test": "jest",
    "test:ci": "jest --runInBand --ci",
    "check": "yarn format:check && yarn check:source-size && yarn type-check && yarn lint && yarn test:ci && yarn build",
    "audit:dependencies": "yarn npm audit --recursive --severity high",
    "test:smoke": "jest --runTestsByPath test/smoke.spec.ts --runInBand",
    "start:dev:trace": "node --trace-deprecation ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "test:smoke:summary": "node -e \"process.env.SMOKE_PRINT_SUMMARY='true'; require('jest/bin/jest');\" --runTestsByPath test/smoke.spec.ts --runInBand",
    "db:migrate:prod": "node scripts/migrate-prod.js",
    "db:migrate:production": "node scripts/migrate-prod.js",
    "render:build": "bash scripts/render-build.sh",
    "render:start": "node scripts/render-start.js",
    "test:smoke:full": "jest --runTestsByPath test/smoke.full.spec.ts --runInBand",
    "test:smoke:all": "yarn test:smoke && yarn test:smoke:full && yarn test:smoke:imports-business",
    "smoke:live": "node scripts/smoke-live.js",
    "test:smoke:imports-business": "jest --runTestsByPath test/smoke.imports-business.spec.ts --runInBand",
    "backup:postgres": "node scripts/backup-postgres.js",
    "db:seed:official": "node scripts/seed-official-user.js",
    "db:clean:official": "node scripts/clean-official-data.js",
    "db:seed:reporteria-contable": "node scripts/seed-reporteria-contable-permissions.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "@types/multer": "^1.4.12"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {"^.+\\.(t|j)s$": "ts-jest"},
    "collectCoverageFrom": ["src/**/*.(t|j)s"],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "engines": {"node": "22.x"},
  "packageManager": "yarn@4.9.2"
}
