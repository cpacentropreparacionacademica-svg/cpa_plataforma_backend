# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TRUST_PROXY=true

# PostgreSQL / Neon
PGHOST=localhost
PGPORT=5432
PGDATABASE=neondb
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=disable
DB_LOGGING=false

# Seguridad
# Sistema privado: por defecto exige sesión.
AUTH_REQUIRED=true
# El alta pública queda deshabilitada. El usuario inicial se crea con seed SQL.
ENABLE_PUBLIC_SIGNUP=false
SESSION_COOKIE_NAME=cpa_session
SESSION_TTL_MINUTES=480
SESSION_COOKIE_SECURE=false
SESSION_SAME_SITE=lax

# Redis opcional para cache de sesiones y rate limit distribuido
# En producción Render puedes usar Upstash/Redis Cloud/KeyDB compatible con Redis.
# Si REDIS_URL queda vacío, el backend funciona igual usando fallback local en memoria.
REDIS_URL=
REDIS_KEY_PREFIX=cpa:backend
REDIS_CONNECT_TIMEOUT_MS=2000
SESSION_CACHE_TTL_SECONDS=300

# Rate limiter: usa Redis si REDIS_URL está configurado; si no, usa fallback en memoria.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Swagger
SWAGGER_ENABLED=true


# TEST USER / SMOKE USER
# Usuario interno para seed y smoke test. No usar nombres ni correos de prueba en producción.
TEST_USER_ID=900001
TEST_USER_EMAIL=pablo.admin@cpa.com
TEST_USER_USERNAME=pablo.admin
TEST_USER_PASSWORD=PabloAdmin2026!
TEST_USER_FIRST_NAME=Pablo
TEST_USER_LAST_NAME=Arauz Caballero
TEST_USER_PHONE=70000000
TEST_USER_TYPE=SUPER_ADMIN
TEST_USER_CLEAN_ID_FROM=900001
TEST_USER_CLEAN_ID_TO=900099

# Alias aceptados por compatibilidad con scripts antiguos.
Email=pablo.admin@cpa.com
Usuario=pablo.admin
Password=PabloAdmin2026!

# Smoke test
# true = prueba POST/PUT/PATCH sin escribir registros basura en la base.
SMOKE_DRY_RUN_CRUD_WRITES=true
SMOKE_RATE_LIMIT_MAX=10000
SMOKE_RATE_LIMIT_WINDOW_MS=900000
SMOKE_PRINT_SUMMARY=false

# Production bootstrap users
# Estos usuarios se crean con yarn db:migrate:prod mediante docs/db/migrations/003_seed_production_users.sql.
# Cambia las contraseñas después del primer acceso real en producción.
PROD_ADMIN_ID=910001
PROD_ADMIN_EMAIL=pablo.admin@cpa.com
PROD_ADMIN_USERNAME=pablo.admin
PROD_ADMIN_PASSWORD=PabloAdmin2026!
PROD_ADMIN_FIRST_NAME=Pablo
PROD_ADMIN_LAST_NAME=Arauz Caballero
PROD_ADMIN_ROLE=ADMIN_GENERAL

PROD_CONTADOR_ID=910002
PROD_CONTADOR_EMAIL=maria.contador@cpa.com
PROD_CONTADOR_USERNAME=maria.contador
PROD_CONTADOR_PASSWORD=MariaContador2026!
PROD_CONTADOR_FIRST_NAME=Maria Sonia
PROD_CONTADOR_LAST_NAME=Caballero
PROD_CONTADOR_ROLE=CONTADOR


# Backup PostgreSQL / Render Cron / Neon destino
# Fuente principal. En Render normalmente basta configurar DATABASE_URL.
# Si no usas DATABASE_URL, el script usa PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD.
DATABASE_URL=postgresql://usuario:password@host-produccion.neon.tech/neondb?sslmode=require

# Ruta local temporal para generar el .sql.gz. En Render usa /tmp.
BACKUP_LOCAL_DIR=/tmp/cpa-backups
BACKUP_PREFIX=cpa-postgres
BACKUP_SOURCE_NAME=cpa-plataforma-backend
BACKUP_DELETE_LOCAL_AFTER_UPLOAD=true

# Schemas que se respaldan. Mantén public porque ahí vive schema_migrations u objetos auxiliares.
BACKUP_SCHEMAS=administracion,contabilidad,deuda,infraestructura,inventario,persona,seguridad,servicios_educativos,societario,public

# Opción A: subir el archivo .sql.gz a un host externo propio.
# Déjalo vacío si solo restaurarás en otro Neon.
BACKUP_UPLOAD_URL=
BACKUP_UPLOAD_TOKEN=
BACKUP_UPLOAD_METHOD=POST
BACKUP_UPLOAD_FIELD=file
BACKUP_UPLOAD_HEADERS_JSON={}

# Opción B: restaurar automáticamente el backup en otra base Neon/PostgreSQL.
# Este debe ser OTRO proyecto/branch/base de Neon, dedicado a backup. Nunca apuntes a producción.
BACKUP_TARGET_DATABASE_URL=postgresql://usuario:password@host-backup.neon.tech/neondb?sslmode=require
BACKUP_RESTORE_TO_TARGET=false
BACKUP_TARGET_CONFIRM=
# Para activar restore automático coloca:
# BACKUP_RESTORE_TO_TARGET=true
# BACKUP_TARGET_CONFIRM=I_UNDERSTAND_TARGET_WILL_BE_REPLACED

# Binarios PostgreSQL. Normalmente se usan estos nombres; si Render/Docker usa otra ruta, configúrala aquí.
PG_DUMP_BIN=pg_dump
PSQL_BIN=psql
