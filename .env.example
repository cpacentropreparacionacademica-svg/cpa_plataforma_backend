# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=api
# Required in production. Comma-separated exact origins; wildcards are rejected.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Use a numeric hop count (for example 1) behind one trusted reverse proxy, or false locally.
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
URL_ENCODED_BODY_LIMIT=256kb
SWAGGER_ENABLED=true

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=cpa_platform
PGUSER=cpa_backend
PGPASSWORD=replace-with-a-secret
PGSSLMODE=disable
# Set true only when the provider uses a private CA that cannot be installed in the image.
PGSSL_REJECT_UNAUTHORIZED=true
DB_LOGGING=false
DB_POOL_MAX=10
DB_POOL_MIN=1
DB_POOL_IDLE_MS=30000
DB_POOL_ACQUIRE_MS=10000
DB_STATEMENT_TIMEOUT_MS=15000
DB_QUERY_TIMEOUT_MS=20000

# Authentication and sessions
AUTH_REQUIRED=true
ENABLE_PUBLIC_SIGNUP=false
SESSION_COOKIE_NAME=cpa_session
SESSION_TTL_MINUTES=480
SESSION_COOKIE_SECURE=false
SESSION_SAME_SITE=lax
SESSION_CACHE_TTL_SECONDS=300
# Opaque session tokens accepted in headers are intended for trusted non-browser clients.
ALLOW_SESSION_HEADER=true
PASSWORD_SCRYPT_COST=16384
PASSWORD_SCRYPT_BLOCK_SIZE=8
PASSWORD_SCRYPT_PARALLELIZATION=1
PASSWORD_SCRYPT_KEY_LENGTH=64
ACTION_TOKEN_TTL_MINUTES=15

# Redis. In production, configure Redis or explicitly accept process-local fallback limits.
REDIS_URL=
REDIS_KEY_PREFIX=cpa:backend
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=1500
REDIS_MAX_RETRIES_PER_REQUEST=1

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_FALLBACK_MAX_BUCKETS=10000
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# Smoke-test account. Use synthetic data only and inject the password from a secret manager.
TEST_USER_ID=900001
TEST_USER_EMAIL=smoke-user@example.invalid
TEST_USER_USERNAME=smoke-user
TEST_USER_PASSWORD=replace-with-a-secret
TEST_USER_FIRST_NAME=Smoke
TEST_USER_LAST_NAME=User
TEST_USER_PHONE=00000000
TEST_USER_TYPE=SMOKE_TEST
TEST_USER_CLEAN_ID_FROM=900001
TEST_USER_CLEAN_ID_TO=900099
SMOKE_DRY_RUN_CRUD_WRITES=true
SMOKE_RATE_LIMIT_MAX=10000
SMOKE_RATE_LIMIT_WINDOW_MS=900000
SMOKE_PRINT_SUMMARY=false

# Bootstrap users. Prefer one-time secret-manager values and mandatory password rotation.
PROD_ADMIN_ID=910001
PROD_ADMIN_EMAIL=admin@example.invalid
PROD_ADMIN_USERNAME=bootstrap-admin
PROD_ADMIN_PASSWORD=replace-with-a-secret
PROD_ADMIN_FIRST_NAME=Bootstrap
PROD_ADMIN_LAST_NAME=Admin
PROD_ADMIN_ROLE=ADMIN_GENERAL

PROD_CONTADOR_ID=910002
PROD_CONTADOR_EMAIL=accountant@example.invalid
PROD_CONTADOR_USERNAME=bootstrap-accountant
PROD_CONTADOR_PASSWORD=replace-with-a-secret
PROD_CONTADOR_FIRST_NAME=Bootstrap
PROD_CONTADOR_LAST_NAME=Accountant
PROD_CONTADOR_ROLE=CONTADOR

# PostgreSQL backup
DATABASE_URL=postgresql://cpa_backend:replace-with-a-secret@localhost:5432/cpa_platform?sslmode=disable
BACKUP_LOCAL_DIR=/tmp/cpa-backups
BACKUP_PREFIX=cpa-postgres
BACKUP_SOURCE_NAME=cpa-platform-backend
BACKUP_DELETE_LOCAL_AFTER_UPLOAD=true
BACKUP_SCHEMAS=administracion,contabilidad,deuda,infraestructura,inventario,persona,seguridad,servicios_educativos,societario,public
BACKUP_UPLOAD_URL=
BACKUP_UPLOAD_TOKEN=
BACKUP_UPLOAD_METHOD=POST
BACKUP_UPLOAD_FIELD=file
BACKUP_UPLOAD_HEADERS_JSON={}
BACKUP_TARGET_DATABASE_URL=
BACKUP_RESTORE_TO_TARGET=false
BACKUP_TARGET_CONFIRM=
BACKUP_TARGET_DROP_SCHEMAS_FIRST=false
BACKUP_TARGET_SINGLE_TRANSACTION=true
BACKUP_DELETE_TEMP_SQL_AFTER_RESTORE=true
PG_DUMP_BIN=pg_dump
PSQL_BIN=psql
